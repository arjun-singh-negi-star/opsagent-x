ENVIRONMENT=development

# --- LLM Engine: DeepSeek-V4 Flash via NVIDIA NIM ---
# Get a free dev key at https://build.nvidia.com/deepseek-ai/deepseek-v4-flash
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-flash

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=opsagentx

# --- Kubernetes / Prometheus ---
K8S_IN_CLUSTER=false
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090
ALLOWED_NAMESPACES=["staging","default"]

# --- Git (CodeFixer's working repo) ---
GIT_REPO_PATH=/repo
GITHUB_TOKEN=

# --- ArgoCD ---
ARGOCD_SERVER=
ARGOCD_TOKEN=

# --- Safety ---
MAX_RETRIES=2
REQUIRE_HUMAN_APPROVAL=true

# --- CORS / frontend ---
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000